{
  "name": "@noobsociety/nsds",
  "version": "0.1.2",
  "description": "NoobSociety Design System — Monokai dark tokens, Tailwind preset, MUI theme, pixel-art React components",
  "keywords": [
    "design-system",
    "react",
    "monokai",
    "tailwind",
    "mui",
    "pixel-art",
    "noobsociety"
  ],
  "author": "NoobSociety",
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "check": "npm run build && npm run check:package && npm run check:types && npm run test:smoke",
    "check:package": "node scripts/check-package.mjs",
    "check:types": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "npm run check",
    "test:smoke": "node scripts/smoke-imports.mjs",
    "release:dry-run": "npm pack --dry-run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noobsociety/nsds.git"
  },
  "bugs": {
    "url": "https://github.com/noobsociety/nsds/issues"
  },
  "homepage": "https://github.com/noobsociety/nsds#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/styles.css",
  "sideEffects": [
    "*.css",
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./mui": {
      "types": "./dist/mui/index.d.ts",
      "import": "./dist/mui/index.js",
      "require": "./dist/mui/index.cjs"
    },
    "./tailwind": "./dist/tailwind/preset.js",
    "./styles": "./dist/styles.css",
    "./styles.css": "./dist/styles.css",
    "./tokens/*": "./dist/tokens/*",
    "./primitives": "./dist/components/primitives.css",
    "./components/primitives.css": "./dist/components/primitives.css",
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "@mui/material": ">=5.0.0",
    "@emotion/react": ">=11.0.0",
    "@emotion/styled": ">=11.0.0"
  },
  "peerDependenciesMeta": {
    "@mui/material": {
      "optional": true
    },
    "@emotion/react": {
      "optional": true
    },
    "@emotion/styled": {
      "optional": true
    }
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.1.1",
    "@types/react": "^19.2.17",
    "@vitejs/plugin-react": "^4.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^3.0.0",
    "typescript": "^6.0.3",
    "vite": "^5.0.0"
  }
}
