{
  "name": "@noobsociety/nsds",
  "version": "0.2.0",
  "description": "NoobSociety Design System — Monokai dark tokens, Tailwind preset, and pixel-art React components",
  "keywords": [
    "design-system",
    "react",
    "monokai",
    "tailwind",
    "pixel-art",
    "noobsociety"
  ],
  "author": "NoobSociety",
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "build:storybook": "storybook build --disable-telemetry",
    "changeset": "changeset",
    "changeset:publish": "changeset publish",
    "changeset:version": "changeset version && node scripts/release-changelog.mjs",
    "check": "npm run build && npm run check:package && npm run check:types && npm run test:smoke",
    "check:package": "node scripts/check-package.mjs",
    "check:types": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "storybook": "storybook dev -p 6006 --disable-telemetry",
    "test": "npm run check",
    "test:smoke": "node scripts/smoke-imports.mjs",
    "release:dry-run": "npm pack --dry-run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noobsociety/nsds.git"
  },
  "bugs": {
    "url": "https://github.com/noobsociety/nsds/issues"
  },
  "homepage": "https://github.com/noobsociety/nsds#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/styles.css",
  "sideEffects": [
    "*.css",
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tailwind": "./dist/tailwind/preset.js",
    "./styles": "./dist/styles.css",
    "./styles.css": "./dist/styles.css",
    "./tokens/*": "./dist/tokens/*",
    "./primitives": "./dist/components/primitives.css",
    "./components/primitives.css": "./dist/components/primitives.css",
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/react": "^19.2.17",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.4.6",
    "tailwindcss": "^3.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
