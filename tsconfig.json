{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022"
  },
  "include": [
    ".storybook/**/*.ts",
    "client/**/*.ts",
    "components/**/*.ts",
    "components/**/*.tsx",
    "global.d.ts",
    "index.ts",
    "scripts/**/*.ts",
    "tailwind/**/*.cts",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "*.config.ts"
  ],
  "exclude": ["dist", "node_modules", "storybook-static"]
}
